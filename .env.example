# ─────────────────────────────────────────────────────────────────────────
# Copy this file to ".env.local" for local development, and set the same
# values in the Vercel dashboard (Settings → Environment Variables) for
# production. See README.md for a step-by-step, non-technical walkthrough.
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection string from Neon / Vercel Postgres.
# Looks like: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# A long random secret used to encrypt login sessions.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# Resend API key, used to send the magic-link login emails.
# Get it free at https://resend.com  (API Keys → Create).
AUTH_RESEND_KEY=

# The "from" address for login emails. During testing you may use
# "onboarding@resend.dev". For production, verify your own domain in Resend
# and use something like "login@yourcompany.com".
EMAIL_FROM=onboarding@resend.dev

# The public URL of the app. For local dev keep http://localhost:3000.
# On Vercel this is set automatically, but you may also set it explicitly
# to your production URL (e.g. https://sg-tracker.vercel.app).
AUTH_URL=http://localhost:3000
